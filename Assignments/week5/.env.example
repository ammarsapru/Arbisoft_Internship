# SerpApi key — https://serpapi.com/manage-api-key
# Used for google_finance, google_finance_markets, google_news, and google (web search) engines
SERPAPI_KEY=

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Model tiers (see docs/07-cost-latency-strategy.md)
MODEL_FAST=claude-haiku-4-5-20251001
MODEL_STRONG=claude-sonnet-5

# SerpApi response cache TTL, in seconds
SERPAPI_CACHE_TTL_SECONDS=900

# Directory for JSONL trace files
TRACE_LOG_DIR=./traces

# Directory for generated Excel reports
REPORT_OUTPUT_DIR=./reports
