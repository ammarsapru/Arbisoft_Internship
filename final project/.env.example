# Copy this file to .env and put secrets only in the copied .env file.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# OPEN_ROUTER_KEY is also accepted as a compatibility alias.
WAYPOINT_MODEL=claude-sonnet-5

# Provider architecture. Keep "single" for the legacy Anthropic/Claude-Code route.
# Set "dual" to split evidence investigation from final answer synthesis.
WAYPOINT_MODEL_ARCHITECTURE=single

# Dual-role configuration. Providers: openrouter, claude-code, anthropic-api, auto.
WAYPOINT_INVESTIGATION_PROVIDER=openrouter
WAYPOINT_INVESTIGATION_MODEL=cohere/north-mini-code:free
WAYPOINT_SYNTHESIS_PROVIDER=claude-code
WAYPOINT_SYNTHESIS_MODEL=claude-fable-5
WAYPOINT_INVESTIGATION_ROUNDS=3
WAYPOINT_SYNTHESIS_MAX_ATTEMPTS=2
WAYPOINT_OPENROUTER_TIMEOUT_SECONDS=180
# WAYPOINT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# For two OpenRouter models instead, use for example:
# WAYPOINT_SYNTHESIS_PROVIDER=openrouter
# WAYPOINT_SYNTHESIS_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# Uses the locally authenticated Claude Code subscription when the API probe fails.
WAYPOINT_CLAUDE_CODE_FALLBACK=1
# Uses the Sonnet alias by default; leave empty to use Claude Code's account default.
WAYPOINT_CLAUDE_CODE_MODEL=sonnet
WAYPOINT_CLAUDE_CODE_TIMEOUT_SECONDS=180
# Internal Claude Code turns used to produce one structured Waypoint action batch.
WAYPOINT_CLAUDE_CODE_MAX_TURNS=8
# Optional hard SDK-session cost ceiling; 0 or blank disables it.
# WAYPOINT_CLAUDE_CODE_MAX_BUDGET_USD=0.35
# Sends one minimal API prompt during backend startup to detect billing/capacity failures.
WAYPOINT_PROVIDER_STARTUP_PROBE=1
WAYPOINT_CHAT_HISTORY_TURNS=12
WAYPOINT_AGENT_MAX_TOOL_ROUNDS=8
WAYPOINT_AGENT_MAX_OUTPUT_TOKENS=6000

# Comma-separated browser origins allowed to call a separately hosted backend.
# Example: https://waypoint-your-team.vercel.app
WAYPOINT_CORS_ORIGINS=

# Optional: increases GitHub API limits for issue history.
GITHUB_TOKEN=

# Optional: persisted chat and analysis state location.
# WAYPOINT_STATE_PATH=.waypoint-data/waypoint.sqlite3

# Optional diagnostics.
ONBOARD_LOG_LEVEL=INFO
ONBOARD_LOG_VALUE_LIMIT=4000
ONBOARD_TRACE_FUNCTIONS=1
ONBOARD_MAX_TRACE=0
ONBOARD_TRACE_FILE=1
# ONBOARD_TRACE_PATH=.waypoint-data/traces/waypoint.jsonl
